# ============================================================================
# Cresselia · Environment Variables
# ============================================================================
# 复制此文件为 .env.local（不会被提交到 git），按需修改。

# Rust axum 后端的绝对 URL（不含末尾斜杠）。
# 本地开发一般就是 http://localhost:3001
# 生产环境一般是内网地址，如 http://backend.internal:8080
AXUM_API_URL=http://localhost:3001
